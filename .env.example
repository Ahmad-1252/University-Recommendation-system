# Environment Configuration for University Recommendation System
# Copy this file to .env and fill in your actual values

# ==========================================
# REQUIRED SETTINGS
# ==========================================

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/
MONGO_CONNECTION_STRING=mongodb://localhost:27017

# Groq API Key (get from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# ==========================================
# OPTIONAL SETTINGS
# ==========================================

# Database Configuration
DATABASE_NAME=university_db
COLLECTION_NAME=programs

# LLM Configuration
GROQ_MODEL=llama3-70b-8192
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# Scraping Configuration
SCRAPE_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=5
RATE_LIMIT_DELAY=2.0
RETRY_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=1.0

# User Agent for scraping
USER_AGENT=UniversityRecommendationBot/1.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE_PATH=logs/app.log

# Export Configuration
EXPORT_DIR=data/exports
EXPORT_FORMATS=csv,json,xlsx

# Application Configuration
DEBUG=false

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================

# Test database (use different database for testing)
TEST_DATABASE_NAME=university_test_db

# Mock external services in tests
MOCK_EXTERNAL_APIS=true