# University Recommendation System Configuration

# MongoDB Settings
MONGO_CONNECTION_STRING=mongodb://localhost:27017
DATABASE_NAME=university_db
COLLECTION_NAME=programs

# LLM Settings
LLM_PROVIDER=deepseek  # deepseek or groq
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GROQ_API_KEY=your_groq_api_key_here
LLM_TEMPERATURE=0.1


# Professional API Key for Admin Endpoints
API_KEY=your_admin_api_key_here

# Scraping Settings
MAX_CONCURRENT_REQUESTS=5
SCRAPE_TIMEOUT=30
RATE_LIMIT_DELAY=1.0

# Logging
LOG_LEVEL=INFO

# Redis Caching (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600
